# OIDC Authentication (QuantumID, Entra ID, Keycloak, Auth0, or any OIDC provider)
OIDC_METADATA_URL=https://auth.quantumapi.eu/.well-known/openid-configuration
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret

# Backend secret (required for OIDC session support and service-to-service auth)
BACKEND_SECRET=change-this-to-a-real-secret

# GitHub integration
GITHUB_TOKEN=ghp_your_token_here

# AI Service (OpenAI-compatible API - Scaleway, Mistral, Azure AI Foundry, OpenAI)
AI_ENDPOINT=https://api.scaleway.ai/v1
AI_KEY=your_api_key
AI_CHAT_MODEL=mistral-small-3.2-24b-instruct-2506
AI_EMBEDDING_MODEL=mistral-embed
AI_PROVIDER=openai   # openai (default, works with Scaleway/Mistral/OpenAI) or azure

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=forge
POSTGRES_PASSWORD=your_password
POSTGRES_DB=forge
