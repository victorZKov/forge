# OIDC Authentication (QuantumID, Entra ID, Keycloak, Auth0, or any OIDC provider)
OIDC_METADATA_URL=https://id.quantumapi.eu/.well-known/openid-configuration
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret

# AI Service (OpenAI-compatible API - Scaleway, Mistral, Azure AI Foundry, OpenAI)
AI_ENDPOINT=https://api.scaleway.ai/v1
AI_KEY=your_api_key
AI_CHAT_MODEL=mistral-large-latest
AI_EMBEDDING_MODEL=mistral-embed
AI_PROVIDER=openai   # openai (default, works with Scaleway/Mistral/OpenAI) or azure

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=forge
POSTGRES_PASSWORD=your_password
POSTGRES_DB=forge
